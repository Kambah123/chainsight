# ── Chainsight backend config ──────────────────────────────────
# Copy this file to .env and fill in your keys. Keys NEVER ship
# to the browser — the frontend only ever talks to this server.

# AI via OpenRouter (recommended — free-tier model, $0 per report)
# Get a free key: https://openrouter.ai/keys
AI_PROVIDER=openrouter
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_MODEL_FALLBACKS=openai/gpt-oss-20b:free,poolside/laguna-s-2.1:free
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Alternative providers (set AI_PROVIDER accordingly)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=mock        # keyless smoke-testing

# On-chain data upgrades (optional — keyless fallbacks work without these)
# Etherscan V2: one key, 50+ EVM chains → https://etherscan.io/apis
ETHERSCAN_KEY=
# Helius: Solana enhanced transactions / SPL flows → https://helius.dev
HELIUS_KEY=

# Server
PORT=8787
# Lock CORS to your frontend origin in production, e.g. https://chainsight.app
ALLOWED_ORIGIN=*
# Used for OpenRouter attribution headers
APP_URL=http://localhost:8787
